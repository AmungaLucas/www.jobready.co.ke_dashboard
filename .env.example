# Database connection
# NOTE: Special characters in password must be URL-encoded:
#   @ → %40    % → %25    # → %23    ? → %3F
# Example: If password is "Amush@100%", encode as "Amush%40100%25"
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Branding (public, exposed to browser)
NEXT_PUBLIC_BRAND_NAME=JobNet
NEXT_PUBLIC_COMPANY_DOMAIN=jobnet.co.ke
NEXT_PUBLIC_SITE_URL=https://www.jobnet.co.ke
NEXT_PUBLIC_WHATSAPP_NUMBER=254786090635
